{
  "name": "n8n-nodes-ai-startup-validator",
  "version": "0.1.0",
  "description": "AI Startup Validator n8n community node that analyzes startup ideas using LLMs and generates validation reports.",
  "license": "MIT",

  "homepage": "https://github.com/mahajan-adi/ai-startup-validator-n8n-node#readme",

  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "ai",
    "startup",
    "validator",
    "llm",
    "automation",
    "gemini",
    "openai"
  ],

  "author": "Aditya Mahajan",

  "repository": {
    "type": "git",
    "url": "git+https://github.com/mahajan-adi/ai-startup-validator-n8n-node.git"
  },

  "bugs": {
    "url": "https://github.com/mahajan-adi/ai-startup-validator-n8n-node/issues"
  },

  "scripts": {
    "build": "n8n-node build",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease"
  },

  "files": [
    "dist"
  ],

  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,

    "credentials": [
      "dist/credentials/AiStartupValidatorApi.credentials.js"
    ],

    "nodes": [
      "dist/nodes/AiStartupValidator/AiStartupValidator.node.js"
    ]
  },

  "devDependencies": {
    "@n8n/node-cli": "0.33.1",
    "eslint": "9.29.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.5",
    "n8n-workflow": "^2.16.0",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3"
  },

  "peerDependencies": {
    "n8n-workflow": "*"
  },

  "dependencies": {
    "axios": "^1.7.9",
    "zod": "^4.4.3"
  }
}